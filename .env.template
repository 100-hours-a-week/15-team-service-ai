# Environment
ENVIRONMENT=production

# vLLM 설정
VLLM_API_KEY=your-vllm-api-key
VLLM_BASE_URL=https://your-runpod-endpoint/openai/v1
VLLM_MODEL=model-name
VLLM_TIMEOUT=120.0

# Gemini 평가용 설정
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EVALUATOR_MODEL=gemini-3.1-pro-preview
GEMINI_TIMEOUT=300.0

# ElevenLabs STT 설정
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_STT_MODEL=scribe_v2

# AWS S3 설정
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=your-s3-bucket-name

# Callback
GENERATE_CALLBACK_URL=http://localhost:8080/api/resume/callback
EDIT_CALLBACK_URL=http://localhost:8080/api/resume
CHAT_CALLBACK_URL=http://localhost:8080/api/ai/callback/interview/message
AI_CALLBACK_SECRET=your-callback-secret

# Timeout
GITHUB_TIMEOUT=60.0
CALLBACK_TIMEOUT=120.0

# Rate Limiting
GITHUB_MAX_CONCURRENT_REQUESTS=5

# Callback Retry
CALLBACK_MAX_RETRIES=3
CALLBACK_RETRY_BASE_DELAY=1.0

# Workflow
WORKFLOW_MAX_RETRIES=2
WORKFLOW_BATCH_SIZE=1

# Logging
LOG_LEVEL=INFO

# Langfuse
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com
